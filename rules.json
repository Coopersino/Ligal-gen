{
  "description": "Правила для неразрывных групп в HTML-лигале маркетингового письма.",
  "nowrapStyle": "white-space: nowrap;",
  "linkStyle": "border-bottom: 1px solid #d1d1d1; margin: 0; text-decoration: none; color: #7D838A; font-family: Helvetica, Arial, sans-serif; white-space: nowrap;",
  "rules": {
    "phrases": [
      "ПАО Сбербанк",
      "законодательством РФ",
      "бизнес-счёта",
      "бизнес-счета",
      "и ИП",
      "а также"
    ],
    "addressParts": [
      "ОГРН\\s+\\d+,",
      "адрес:\\s+\\d{6},",
      "г\\.\\s+[^,]+,",
      "ул\\.\\s+[^,]+,",
      "д\\.\\s+[^,]+,",
      "стр\\.\\s+[^,]+,",
      "корп\\.\\s+[^,]+,",
      "оф\\.\\s+[^,]+,"
    ],
    "prefixWords": [
      "а",
      "без",
      "в",
      "во",
      "для",
      "до",
      "за",
      "и",
      "из",
      "к",
      "ко",
      "на",
      "о",
      "об",
      "от",
      "по",
      "при",
      "с",
      "со",
      "у",
      "не",
      "под"
    ],
    "abbreviationBefore": [
      "г.",
      "д.",
      "ул.",
      "стр.",
      "корп.",
      "оф.",
      "п.",
      "пп.",
      "кв.",
      "№"
    ],
    "numberUnits": [
      "%",
      "₽",
      "руб.",
      "рублей",
      "млн",
      "тыс.",
      "шт."
    ],
    "datePrefixes": [
      "с",
      "по",
      "от"
    ],
    "connectDash": true
  }
}
